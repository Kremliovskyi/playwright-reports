{
  "name": "playwright-reports",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "concurrently \"tsc -p tsconfig.server.json\" \"tsc -p tsconfig.client.json\" && npm run copy-assets",
    "copy-assets": "cp -r src/public/index.html src/public/style.css dist/public/ && cp config.json dist/ || true",
    "start": "npm run build && pm2 start ecosystem.config.js",
    "stop": "pm2 stop playwright-reports",
    "restart": "pm2 restart playwright-reports",
    "logs": "pm2 logs playwright-reports",
    "delete": "pm2 delete playwright-reports",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pm2": "^6.0.14"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}
