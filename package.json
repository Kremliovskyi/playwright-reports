    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jiti": "^2.6.1",
    "markdown-it": "^14.1.1",
    "pm2": "^6.0.14",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
